{
  "name": "@gemini/mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Gemini CLI integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gemini-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc && chmod +x dist/*.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "gemini",
    "google",
    "ai",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "dotenv": "^16.4.5",
    "winston": "^3.14.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
